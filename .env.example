# Server
NODE_ENV=development
PORT=4000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/erp_expenses_app

# JWT (use long random strings in real .env)
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret

# CORS
CORS_ORIGIN=http://localhost:5173

# Cookies
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax